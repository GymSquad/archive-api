{
    "swagger": "2.0",
    "info": {
        "description": "Minimal API for the NYCU Library Web Archive project",
        "title": "NYCU Library Web Archive API",
        "contact": {},
        "version": "1.0.0"
    },
    "host": "localhost:8080",
    "basePath": "/api",
    "paths": {
        "/search": {
            "get": {
                "description": "Search the archives",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "archive"
                ],
                "summary": "Search archives",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Search query",
                        "name": "q",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Cursor",
                        "name": "cursor",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Limit",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/searcharchives.SearchArchivesResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid input",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/website/{websiteId}": {
            "get": {
                "description": "Get the dates that a website was archived",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "archive"
                ],
                "summary": "Get archived dates",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Website ID",
                        "name": "websiteId",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of dates",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "searcharchives.SearchArchivesPagination": {
            "type": "object",
            "properties": {
                "next_cursor": {
                    "type": "string"
                }
            }
        },
        "searcharchives.SearchArchivesResponse": {
            "type": "object",
            "properties": {
                "pagination": {
                    "$ref": "#/definitions/searcharchives.SearchArchivesPagination"
                },
                "results": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/searcharchives.SearchArchivesResult"
                    }
                }
            }
        },
        "searcharchives.SearchArchivesResult": {
            "type": "object",
            "properties": {
                "archive_id": {
                    "type": "string"
                },
                "date": {
                    "type": "string"
                },
                "website_id": {
                    "type": "string"
                }
            }
        }
    }
}